# slack-monitor configuration example
# Copy this file to config.toml and customize as needed.
#
# SECURITY NOTE: NEVER set api_key in this file.
# Use the SLACK_MONITOR_API_KEY or OPENAI_API_KEY environment variable instead.

[llm]
# OpenAI-compatible API base URL
# LM Studio (local):    http://localhost:1234/v1
# litellm-proxy:        http://localhost:4000/v1  (with appropriate route configured)
base_url = "http://localhost:1234/v1"

# Model ID as expected by the API
# LM Studio local:      openai/gpt-oss-20b
# litellm-proxy Gemini: vertex_ai/gemini-2.0-flash
model = "openai/gpt-oss-20b"

# Maximum tokens in LLM response
max_tokens = 2048

# LLM temperature (lower = more deterministic)
# Recommended: 0.0-0.3 for structured output
temperature = 0.3

[buffer]
# Flush buffer after this many seconds (time-based trigger)
window_seconds = 60

# Trigger analysis when this many messages are buffered (responsive count trigger)
# Lower values = faster response to activity bursts
trigger_messages = 10

# Hard overflow cap — force flush before context window is exceeded
max_messages = 50

# Hard character ceiling for buffered messages (~45K token headroom for 64K context models)
max_chars = 180000

[output]
# Language for the analysis summary. "auto" follows the language of the messages.
# Examples: "Japanese", "English", "Korean"
analysis_language = "auto"

# Print raw LLM JSON response below each analysis panel (useful for debugging)
show_raw = false

# Timezone for display ("local" uses system timezone, or use IANA name like "Asia/Tokyo")
timezone = "local"
