# Environment variables for slack-monitor
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# API key for the LLM service (required for non-local APIs)
# For LM Studio (local): can be any non-empty string, e.g. "lm-studio"
# For OpenAI: your sk-... key
# For litellm-proxy: your proxy auth token
SLACK_MONITOR_API_KEY=lm-studio

# Optional: override config file settings via environment
# SLACK_MONITOR_BASE_URL=http://localhost:1234/v1
# SLACK_MONITOR_MODEL=openai/gpt-oss-20b
# SLACK_MONITOR_WINDOW_SECONDS=60
# SLACK_MONITOR_MAX_MESSAGES=50
# SLACK_MONITOR_SHOW_RAW=false
# SLACK_MONITOR_CONFIG=/path/to/config.toml
